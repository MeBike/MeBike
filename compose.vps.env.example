# Copy to compose.vps.env before running Docker Compose.
# Start the shared Traefik stack in `infra/traefik` first.
# Example commands:
# docker compose --env-file compose.vps.env -f compose.vps.yaml run --rm server-migrate
# docker compose --env-file compose.vps.env -f compose.vps.yaml up -d --build

COMPOSE_PROJECT_NAME=mebike
COMPOSE_ENV_FILE=./compose.vps.env
IMAGE_TAG=latest

TRAEFIK_NETWORK=traefik-public
TRAEFIK_CERT_RESOLVER=default

APEX_DOMAIN=mebike.site
FRONTEND_HOST=mebike.site
FRONTEND_WWW_HOST=www.mebike.site
SERVER_HOST=api.mebike.site

POSTGRES_USER=mebike
POSTGRES_PASSWORD=change-me
POSTGRES_DB=mebike
PRISMA_TRANSACTION_TIMEOUT_MS=10000

IOT_MQTT_USERNAME=change-me
IOT_MQTT_PASSWORD=change-me

NEXT_PUBLIC_API_BASE_URL=https://api.mebike.site/v1
NEXT_PUBLIC_TOMTOM_API_KEY=
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

EMAIL_APP=
EMAIL_PASSWORD_APP=
JWT_SECRET=change-me
LOG_LEVEL=info
BCRYPT_SALT_ROUNDS=10

FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
GOOGLE_APPLICATION_CREDENTIALS=
MAPBOX_ACCESS_TOKEN=

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

OPENROUTER_API_KEY=
OPENROUTER_SITE_URL=https://mebike.site
OPENROUTER_APP_NAME=MeBike
AI_MODEL=deepseek/deepseek-v4-flash
OPENROUTER_PROVIDER_ORDER=siliconflow,deepinfra
OPENROUTER_PROVIDER_ONLY=
OPENROUTER_PROVIDER_QUANTIZATIONS=fp8,fp4
OPENROUTER_ALLOW_FALLBACKS=true
OPENROUTER_REASONING_EFFORT=medium

MIN_WITHDRAWAL_AMOUNT=5
WITHDRAWAL_PROCESSING_TTL_MINUTES=10
WITHDRAWAL_SLA_MINUTES=5
WITHDRAWAL_SWEEP_CRON=*/5 * * * *

STATION_CAPACITY_LIMIT=40
RESERVATION_HOLD_MINUTES=30
EXPIRY_NOTIFY_MINUTES=15
REFUND_PERIOD_HOURS=24
FIXED_SLOT_ASSIGN_CRON=0 0 * * *
SUB_HOURS_PER_USED=10
EXPIRE_AFTER_DAYS=30
AUTO_ACTIVATE_IN_DAYS=10

# Copy to /etc/mebike/postgres-backup.env on the VPS.
# Keep owned by root and mode 600 because it contains the database password.

BACKUP_DIR=/var/backups/mebike/postgres
POSTGRES_CONTAINER=postgres-ua60yxcend5bm577cvs1rqii-150538524704
POSTGRES_USER=mebike
POSTGRES_PASSWORD=replace-me
POSTGRES_DB=mebike
RETENTION_DAYS=14

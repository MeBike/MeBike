# Copy file nay thanh .env va dien gia tri.
# Xem src/config/env.ts de biet schema/day du defaults.
NODE_ENV=development
PORT=4000

# Postgres (can PostGIS + pgvector)
DATABASE_URL=postgresql://mebike:mebike@localhost:5432/mebike
PRISMA_TRANSACTION_TIMEOUT_MS=5000

# Redis
REDIS_URL=redis://localhost:6379

# MQTT cho IoT runtime (local compose mac dinh dung Mosquitto o 1883)
IOT_MQTT_URL=mqtt://localhost:1883
IOT_MQTT_USERNAME=
IOT_MQTT_PASSWORD=

# Auth
JWT_SECRET=change-me
BCRYPT_SALT_ROUNDS=10

# Email (bat buoc theo env schema)
EMAIL_APP=dev@example.com
EMAIL_PASSWORD_APP=dummy

# Firebase Storage (optional)
FIREBASE_PROJECT_ID=mebike-1ee36
FIREBASE_STORAGE_BUCKET=mebike-1ee36.firebasestorage.app
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/firebase-service-account.json

# Stripe (optional)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# OpenRouter AI (optional)
OPENROUTER_API_KEY=
OPENROUTER_SITE_URL=
OPENROUTER_APP_NAME=MeBike
AI_MODEL=deepseek/deepseek-v4-flash
OPENROUTER_PROVIDER_ORDER=siliconflow,deepinfra
OPENROUTER_PROVIDER_ONLY=
OPENROUTER_PROVIDER_QUANTIZATIONS=fp8,fp4
OPENROUTER_ALLOW_FALLBACKS=true
OPENROUTER_REASONING_EFFORT=medium

# Wallet/withdrawal tuning (optional)
MIN_WITHDRAWAL_AMOUNT=5
WITHDRAWAL_PROCESSING_TTL_MINUTES=10
WITHDRAWAL_SLA_MINUTES=5
WITHDRAWAL_SWEEP_CRON=*/5 * * * *

# Business config (optional)
MIN_WALLET_BALANCE_TO_RENT=2000
STATION_CAPACITY_LIMIT=20
RESERVATION_HOLD_MINUTES=30
RESERVATION_PREPAID_AMOUNT=2000
RETURN_SLOT_RESERVATION_FEE_MINOR=2000
EXPIRY_NOTIFY_MINUTES=15
REFUND_PERIOD_HOURS=24
FIXED_SLOT_ASSIGN_CRON=0 0 * * *
PRICE_PER_30_MINS=2000
SUB_HOURS_PER_USED=10
RENTAL_PENALTY_HOURS=24
RENTAL_PENALTY_AMOUNT=50000
EXPIRE_AFTER_DAYS=30
AUTO_ACTIVATE_IN_DAYS=10

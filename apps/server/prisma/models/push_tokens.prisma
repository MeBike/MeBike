enum PushTokenPlatform {
  ANDROID
  IOS
  UNKNOWN
}

model PushToken {
  id         String            @id @default(uuid(7)) @db.Uuid
  userId     String            @map("user_id") @db.Uuid
  token      String            @unique @db.Text
  platform   PushTokenPlatform @default(UNKNOWN)
  deviceId   String?           @map("device_id") @db.Text
  appVersion String?           @map("app_version") @db.Text
  isActive   Boolean           @default(true) @map("is_active")
  lastSeenAt DateTime          @default(now()) @map("last_seen_at") @db.Timestamptz
  createdAt  DateTime          @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime          @updatedAt @map("updated_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([userId, isActive], name: "idx_push_tokens_user_active")
  @@map("push_tokens")
}

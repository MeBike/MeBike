enum ConfirmationMethod {
  QR_CODE
  MANUAL

  @@map("confirmation_method")
}

enum HandoverStatus {
  PENDING
  CONFIRMED
  UNDER_STATION_CARE
  UNDER_AGENCY_CARE
  DISPUTED

  @@map("handover_status")
}

enum RentalPenaltyType {
  LATE_RETURN
  LOSS
  DAMAGE
  OTHER

  @@map("rental_penalty_type")
}

model ReturnConfirmation {
  id                 String             @id @default(uuid(7)) @db.Uuid
  rentalId           String             @unique @map("rental_id") @db.Uuid
  stationId          String?            @map("station_id") @db.Uuid
  confirmedByUserId  String             @map("confirmed_by_user_id") @db.Uuid
  confirmationMethod ConfirmationMethod @default(QR_CODE) @map("confirmation_method")
  handoverStatus     HandoverStatus     @default(PENDING) @map("handover_status")
  confirmedAt        DateTime           @map("confirmed_at") @db.Timestamptz
  createdAt          DateTime           @default(now()) @map("created_at") @db.Timestamptz

  rental          Rental   @relation(fields: [rentalId], references: [id])
  station         Station? @relation("ReturnConfirmationStation", fields: [stationId], references: [id])
  confirmedByUser User     @relation(fields: [confirmedByUserId], references: [id])

  @@index([stationId], name: "idx_return_confirmations_station")
  @@index([confirmedByUserId], name: "idx_return_confirmations_confirmed_by_user")
  @@map("return_confirmations")
}

model RentalBillingRecord {
  id                         String   @id @default(uuid(7)) @db.Uuid
  rentalId                   String   @unique @map("rental_id") @db.Uuid
  pricingPolicyId            String   @map("pricing_policy_id") @db.Uuid
  totalDurationMinutes       Int      @map("total_duration_minutes")
  estimatedDistanceKm        Decimal? @map("estimated_distance_km") @db.Decimal(8, 2)
  baseAmount                 Decimal  @default(0) @map("base_amount") @db.Decimal(12, 2)
  overtimeAmount             Decimal  @default(0) @map("overtime_amount") @db.Decimal(12, 2)
  couponRuleId               String?  @map("coupon_rule_id") @db.Uuid
  couponRuleSnapshot         Json?    @map("coupon_rule_snapshot") @db.JsonB
  couponDiscountAmount       Decimal  @default(0) @map("coupon_discount_amount") @db.Decimal(12, 2)
  subscriptionDiscountAmount Decimal  @default(0) @map("subscription_discount_amount") @db.Decimal(12, 2)
  depositForfeited           Boolean  @default(false) @map("deposit_forfeited")
  totalAmount                Decimal  @map("total_amount") @db.Decimal(12, 2)
  createdAt                  DateTime @default(now()) @map("created_at") @db.Timestamptz

  rental        Rental        @relation(fields: [rentalId], references: [id])
  pricingPolicy PricingPolicy @relation(fields: [pricingPolicyId], references: [id])
  couponRule    CouponRule?   @relation(fields: [couponRuleId], references: [id])

  @@index([pricingPolicyId], name: "idx_rental_billing_records_pricing_policy")
  @@index([couponRuleId], name: "idx_rental_billing_records_coupon_rule")
  @@map("rental_billing_records")
}

model RentalPenalty {
  id           String            @id @default(uuid(7)) @db.Uuid
  rentalId     String            @map("rental_id") @db.Uuid
  walletHoldId String?           @map("wallet_hold_id") @db.Uuid
  penaltyType  RentalPenaltyType @map("penalty_type")
  amount       Decimal           @db.Decimal(12, 2)
  description  String?
  createdAt    DateTime          @default(now()) @map("created_at") @db.Timestamptz

  rental     Rental      @relation(fields: [rentalId], references: [id])
  walletHold WalletHold? @relation(fields: [walletHoldId], references: [id])

  @@index([rentalId], name: "idx_rental_penalties_rental")
  @@index([walletHoldId], name: "idx_rental_penalties_wallet_hold")
  @@map("rental_penalties")
}

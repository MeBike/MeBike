// Enums specific to users
enum UserRole {
  USER
  STAFF
  TECHNICIAN
  MANAGER
  ADMIN
  AGENCY
}

enum UserVerifyStatus {
  UNVERIFIED
  VERIFIED
}

// Users table

model User {
  id                       String           @id @default(uuid(7)) @db.Uuid
  fullName                 String           @map("full_name")
  email                    String           @unique
  phoneNumber              String?          @unique @map("phone_number")
  username                 String?
  passwordHash             String           @map("password_hash")
  avatarUrl                String?          @map("avatar_url")
  locationText             String?          @map("location_text")
  nfcCardUid               String?          @map("nfc_card_uid")
  role                     UserRole         @default(USER)
  accountStatus            AccountStatus    @default(ACTIVE) @map("account_status")
  verifyStatus             UserVerifyStatus @default(UNVERIFIED) @map("verify_status")
  stripeConnectedAccountId String?          @unique @map("stripe_connected_account_id") @db.Text
  stripePayoutsEnabled     Boolean?         @map("stripe_payouts_enabled")
  createdAt                DateTime         @default(now()) @map("created_at") @db.Timestamptz
  updatedAt                DateTime         @updatedAt @map("updated_at") @db.Timestamptz

  authEvents                      AuthEvent[]
  subscriptions                   Subscription[]
  fixedSlots                      FixedSlotTemplate[]
  reservations                    Reservation[]
  rentals                         Rental[]
  ratings                         Rating[]
  wallet                          Wallet?
  payments                        Payment[]
  paymentAttempts                 PaymentAttempt[]
  withdrawals                     WalletWithdrawal[]
  bikeSwapRequests                BikeSwapRequest[]
  pushTokens                      PushToken[]
  orgAssignment                   UserOrgAssignment?
  userCoupons                     UserCoupon[]
  returnConfirmations             ReturnConfirmation[]
  returnSlotReservations          ReturnSlotReservation[]
  reportedIncidents               IncidentReport[]
  technicianAssignments           TechnicianAssignment[]    @relation("TechnicianAssignmentTechnicianUser")
  assignedTechnicianAssignments   TechnicianAssignment[]    @relation("TechnicianAssignmentAssignedByUser")
  bikeMaintenanceLogs             BikeMaintenanceLog[]
  requestedRedistributionRequests RedistributionRequest[]   @relation("RedistributionRequestRequestedByUser")
  approvedRedistributionRequests  RedistributionRequest[]   @relation("RedistributionRequestApprovedByUser")
  environmentalImpactStats        EnvironmentalImpactStat[]

  submittedAgencyRequests   AgencyRequest[] @relation("AgencyRequestRequester")
  reviewedAgencyRequests    AgencyRequest[] @relation("AgencyRequestReviewer")
  createdAgencyUserRequests AgencyRequest[] @relation("AgencyRequestCreatedAgencyUser")

  @@index([email], name: "idx_users_email")
  @@index([phoneNumber], name: "idx_users_phone")
  @@index([nfcCardUid], name: "idx_users_nfc", type: Brin) // partial index not expressible; BRIN as placeholder
  @@map("users")
}

// Stations table

model Station {
  id              String                                @id @default(uuid(7)) @db.Uuid
  name            String                                @unique
  address         String
  totalCapacity   Int                                   @map("total_capacity")
  pickupSlotLimit Int                                   @default(0) @map("pickup_slot_limit")
  returnSlotLimit Int                                   @default(0) @map("return_slot_limit")
  latitude        Float
  longitude       Float
  createdAt       DateTime                              @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime                              @map("updated_at") @db.Timestamptz
  position        Unsupported("geography(Point, 4326)")

  bikes                        Bike[]
  reservations                 Reservation[]
  rentalsStart                 Rental[]                @relation("RentalStartStation")
  rentalsEnd                   Rental[]                @relation("RentalEndStation")
  fixedSlots                   FixedSlotTemplate[]
  bikeSwapRequests             BikeSwapRequest[]
  technicianTeams              TechnicianTeam[]
  userAssignments              UserOrgAssignment[]
  returnConfirmations          ReturnConfirmation[]    @relation("ReturnConfirmationStation")
  returnSlotReservations       ReturnSlotReservation[]
  incidentReports              IncidentReport[]
  sourceRedistributionRequests RedistributionRequest[] @relation("RedistributionRequestSourceStation")
  targetRedistributionRequests RedistributionRequest[] @relation("RedistributionRequestTargetStation")

  @@map("Station")
}

model GeoBoundary {
  code String                                     @id
  geom Unsupported("geometry(MultiPolygon,4326)")

  @@index([geom], type: Gist, map: "GeoBoundary_geom_gix")
  @@map("GeoBoundary")
}

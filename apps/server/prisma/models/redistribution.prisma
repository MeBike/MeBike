enum RedistributionStatus {
  PENDING_APPROVAL
  APPROVED
  REJECTED
  IN_TRANSIT
  PARTIALLY_COMPLETED
  COMPLETED
  CANCELLED

  @@map("redistribution_status")
}

model RedistributionRequest {
  id                String               @id @default(uuid(7)) @db.Uuid
  requestedByUserId String               @map("requested_by_user_id") @db.Uuid
  approvedByUserId  String?              @map("approved_by_user_id") @db.Uuid
  sourceStationId   String               @map("source_station_id") @db.Uuid
  targetStationId   String?              @map("target_station_id") @db.Uuid
  targetAgencyId    String?              @map("target_agency_id") @db.Uuid
  reason            String?
  requestedQuantity Int                 @map("requested_quantity")
  status            RedistributionStatus @default(PENDING_APPROVAL)
  startedAt         DateTime?            @map("started_at") @db.Timestamptz
  completedAt       DateTime?            @map("completed_at") @db.Timestamptz
  createdAt         DateTime             @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime             @updatedAt @map("updated_at") @db.Timestamptz

  requestedByUser User                        @relation("RedistributionRequestRequestedByUser", fields: [requestedByUserId], references: [id])
  approvedByUser  User?                       @relation("RedistributionRequestApprovedByUser", fields: [approvedByUserId], references: [id])
  sourceStation   Station                     @relation("RedistributionRequestSourceStation", fields: [sourceStationId], references: [id])
  targetStation   Station?                    @relation("RedistributionRequestTargetStation", fields: [targetStationId], references: [id])
  targetAgency    Agency?                     @relation("RedistributionRequestTargetAgency", fields: [targetAgencyId], references: [id])
  items           RedistributionRequestItem[]

  @@index([requestedByUserId], name: "idx_redistribution_requests_requested_by")
  @@index([approvedByUserId], name: "idx_redistribution_requests_approved_by")
  @@index([sourceStationId], name: "idx_redistribution_requests_source_station")
  @@index([targetStationId], name: "idx_redistribution_requests_target_station")
  @@index([targetAgencyId], name: "idx_redistribution_requests_target_agency")
  @@index([status], name: "idx_redistribution_requests_status")
  @@map("redistribution_requests")
}

model RedistributionRequestItem {
  id                      String                @id @default(uuid(7)) @db.Uuid
  redistributionRequestId String                @map("redistribution_request_id") @db.Uuid
  bikeId                  String                @map("bike_id") @db.Uuid
  deliveredAt             DateTime?             @map("delivered_at") @db.Timestamptz
  createdAt               DateTime              @default(now()) @map("created_at") @db.Timestamptz
  redistributionRequest   RedistributionRequest @relation(fields: [redistributionRequestId], references: [id], onDelete: Cascade)
  bike                    Bike?                 @relation(fields: [bikeId], references: [id])

  @@index([redistributionRequestId], name: "idx_redistribution_request_items_request")
  @@index([bikeId], name: "idx_redistribution_request_items_bike")
  @@map("redistribution_request_items")
}

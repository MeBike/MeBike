model PricingPolicy {
  id                 String        @id @default(uuid(7)) @db.Uuid
  name               String
  baseRate           BigInt        @map("base_rate") @db.BigInt
  billingUnitMinutes Int           @map("billing_unit_minutes")
  reservationFee     BigInt        @default(2000) @map("reservation_fee") @db.BigInt
  depositRequired    BigInt        @default(500000) @map("deposit_required") @db.BigInt
  lateReturnCutoff   DateTime      @default(dbgenerated("'23:00:00'::time without time zone")) @map("late_return_cutoff") @db.Time
  status             AccountStatus @default(ACTIVE)
  createdAt          DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime      @updatedAt @map("updated_at") @db.Timestamptz

  reservations         Reservation[]
  rentals              Rental[]
  rentalBillingRecords RentalBillingRecord[]

  @@map("pricing_policies")
}
